# Backend
AIDA_DEPLOYMENT_MODE=local
AIDA_DATABASE_URL=sqlite:///./.data/app.db
AIDA_REDIS_URL=redis://localhost:6379/0
AIDA_USE_RQ=false
AIDA_MEDIA_TTL_MINUTES=15
AIDA_JOB_TTL_HOURS=24
AIDA_ALLOWED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
AIDA_MAX_UPLOAD_BYTES=15728640
AIDA_REQUIRE_ACCESS_TOKEN=false
AIDA_ACCESS_TOKEN_SHA256=
AIDA_RATE_LIMIT_ENABLED=true
AIDA_RATE_LIMIT_WINDOW_SECONDS=60
AIDA_RATE_LIMIT_MAX_REQUESTS=120
AIDA_ANALYSIS_RATE_LIMIT_MAX_REQUESTS=12
AIDA_METRICS_ENABLED=true
AIDA_AUDIT_SALT=local-dev-audit-salt

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIDA_ENCRYPTION_KEY=

# Optional open-source detector adapter. Install backend/requirements-ml.txt before enabling.
AIDA_ENABLE_HF_MODEL=false
AIDA_HF_MODEL_ID=buildborderless/CommunityForensics-DeepfakeDet-ViT
AIDA_HF_MODEL_IDS=buildborderless/CommunityForensics-DeepfakeDet-ViT,Ateeqq/ai-vs-human-image-detector,jacoballessio/ai-image-detect-distilled

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_REQUIRE_ACCESS_TOKEN=false
