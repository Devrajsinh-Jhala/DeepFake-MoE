# Copy to .env.production and fill real values before deploying.

POSTGRES_PASSWORD=change-this-long-random-password

# Backend production hardening
AIDA_DEPLOYMENT_MODE=production
AIDA_USE_RQ=true
AIDA_DATA_DIR=/data
AIDA_MEDIA_TTL_MINUTES=15
AIDA_JOB_TTL_HOURS=24
AIDA_MAX_UPLOAD_BYTES=15728640
AIDA_ALLOWED_ORIGINS=["https://your-domain.example"]
AIDA_REQUIRE_ACCESS_TOKEN=false

# Optional private-beta gate. If AIDA_REQUIRE_ACCESS_TOKEN=true, generate an access token,
# give it only to approved users, then store only its SHA-256:
# python -c "import hashlib; token='replace-with-long-random-access-token'; print(hashlib.sha256(token.encode()).hexdigest())"
AIDA_ACCESS_TOKEN_SHA256=
AIDA_RATE_LIMIT_ENABLED=true
AIDA_RATE_LIMIT_WINDOW_SECONDS=60
AIDA_RATE_LIMIT_MAX_REQUESTS=120
AIDA_ANALYSIS_RATE_LIMIT_MAX_REQUESTS=12
AIDA_METRICS_ENABLED=false
AIDA_AUDIT_SALT=replace-with-random-audit-salt

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIDA_ENCRYPTION_KEY=replace-with-fernet-key

# Open-source detector ensemble
AIDA_ENABLE_HF_MODEL=true
AIDA_HF_MODEL_IDS=Ateeqq/ai-vs-human-image-detector,dima806/ai_vs_real_image_detection,jacoballessio/ai-image-detect-distilled,SadraCoding/SDXL-Deepfake-Detector

# Leave blank for same-origin production serving.
VITE_API_BASE_URL=
VITE_REQUIRE_ACCESS_TOKEN=false
